<body>
    <header>
        <h1>Beer Dollars</h1>
    </header>
    <input type="text" id="search" placeholder="Search bars or specials...">

    <div class="days" id="dayTabs">
        <!-- JS will populate -->
    </div>

    <div class="bar-list" id="barList">
        <!-- Cards populated by JS fetch -->
    </div>

    <div id="map" class="map-container"></div>

    <div class="add-btn" onclick="showAddForm()">+</div>

    <script>
        const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
        const funLabels = ['Chill Vibes', 'Monday Blues Buster', 'Taco... wait no, Beer Tuesday', 'Hump Day', 'Thirsty Thursday', 'TGIF', 'Weekend Warrior'];
        const todayIndex = new Date().getDay();  // 0=Sun, 6=Sat

        // Populate day tabs
        const tabs = document.getElementById('dayTabs');
        days.forEach((day, i) => {
            const tab = document.createElement('div');
            tab.className = 'day-tab' + (i === todayIndex ? ' active' : '');
            tab.textContent = `\( {day} ( \){funLabels[i]})`;
            tab.onclick = () => loadBars(day.toLowerCase());
            tabs.appendChild(tab);
        });

        // Fetch and display bars (call your /api/bars?day=thursday&lat=...&lng=...)
        function loadBars(day) {
            navigator.geolocation.getCurrentPosition(pos => {
                fetch(`/api/bars?day=\( {day}&lat= \){pos.coords.latitude}&lng=${pos.coords.longitude}&radius=35`)
                    .then(res => res.json())
                    .then(data => {
                        const list = document.getElementById('barList');
                        list.innerHTML = '';
                        data.bars.forEach(bar => {
                            const card = document.createElement('div');
                            card.className = 'bar-card';
                            card.innerHTML = `
                                <div class="beer-icon">🍺</div>
                                <div>
                                    <strong>${bar.name}</strong><br>
                                    ${bar.deal}<br>
                                    ${bar.distance ? bar.distance + ' miles away' : 'Nearby'}
                                </div>
                            `;
                            list.appendChild(card);
                        });
                    });
            });
        }

        // Init map (basic placeholder)
        function initMap() {
            // Add your map init with pins from bars
        }

        // Load today's bars on start
        loadBars(days[todayIndex].toLowerCase());

        function showAddForm() {
            // Redirect or modal to add bar form
            window.location.href = "/add";  // Or open modal
        }
    </script>
</body>
</html>
